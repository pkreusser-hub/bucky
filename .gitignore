# dev tooling — not part of the deployed site
tools/node_modules/
shots/
*.log

# local claude session config (skills and launch config ARE tracked)
.claude/settings.local.json

# netlify local state
.netlify/

# functions dependencies get installed by netlify at build time
netlify/functions/node_modules/
tools/.env
*.key

# farm life dev dependencies (dist IS committed - static deploy)
farmlife/node_modules/

# blender backups + tool output noise + local editor config + root test scratch
*.blend1
*.blend.bak
tools/_inspect-*.txt
tools/_verify-out.txt
.vscode/
scratchpad/

# Tripo cast RAW intermediates (per-clip FBX + rig dirs, ~600MB/member) — only the root GLBs ship
assets/cast/*/*/

# Gator 3D RAW Tripo intermediates (57MB source + wheel experiments) — only farmkart-gator3d.glb ships
assets/farmkart/gator3d/
